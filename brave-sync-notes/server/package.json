{
  "name": "brave-sync-server",
  "version": "2.2.0",
  "description": "Secure end-to-end encrypted note sync server",
  "main": "index.js",
  "keywords": [
    "sync",
    "notes",
    "encrypted",
    "websocket",
    "real-time"
  ],
  "author": "NoteSync Team",
  "license": "MIT",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:property": "jest --testPathPattern=property.test.js",
    "start": "node index.js",
    "dev": "node index.js",
    "lint": "eslint . --ext .js --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\""
  },
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "socket.io": "^4.8.1",
    "redis": "^4.6.0",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "fast-check": "^3.15.0"
  }
}